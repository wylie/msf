---
const { src = "../img/hero-01.png", alt = "hero image" } = Astro.props;
---

<figure class="hero" aria-live="polite" aria-atomic="true">
  <img id="hero-image" src={src} alt={alt} data-hero-image />
</figure>

<style>
  .hero {
    width: 100%;
    height: 100%;
    min-width: 0;
    min-height: 0;
    overflow: hidden;
    background-color: #fff;
    margin: 0;
  }
  img {
    display: block;
    width: 100%;
    height: 100%;
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }
</style>
