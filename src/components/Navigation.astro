---
const { style } = Astro.props;
---

<header class="wrap" style={style}>
  <div class="outer">
    <h1 class="name special"><a href="/">Mark S. Fisher</a></h1>
    <nav aria-label="Social and contact links">
      <ul class="inner">
        <li>
          <a data-nav-icon="instagram" href="https://www.instagram.com/marksfisher3/" target="_blank" rel="noopener noreferrer" aria-label="Visit Mark S. Fisher on Instagram">
            <img class="social" src="/img/instagram.png" alt="" />
          </a>
        </li>
        <li>
          <a data-nav-icon="behance" href="https://www.behance.net/Marksfisher" target="_blank" rel="noopener noreferrer" aria-label="Visit Mark S. Fisher on Behance">
            <img class="social" src="/img/behance.png" alt="" />
          </a>
        </li>
        <li>
          <a data-nav-icon="flickr" href="https://www.flickr.com/photos/15067667@N04/" target="_blank" rel="noopener noreferrer" aria-label="Visit Mark S. Fisher on Flickr">
            <img class="social" src="/img/flickr.png" alt="" />
          </a>
        </li>
        <li>
          <a data-nav-icon="email" href="mailto:mark@marksfisher.com" aria-label="Email Mark S. Fisher">
            <span class="contact material-icons" aria-hidden="true">mail</span>
          </a>
        </li>
      </ul>
    </nav>
  </div>
</header>

<style>
  .wrap {
    width: 100%;
  }
  .outer {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    padding: 1rem;
    background-color: #efefef;
  }
  .inner {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  nav {
    width: auto;
  }
  li {
    margin: 0;
    padding: 0;
  }

  a {
    position: relative;
    top: 0;
    flex: 0 0 auto;
    color: inherit;
    text-decoration: none;
    transition: top .2s ease;
  }
  a:hover {
    top: -2px;
  }
  a:active {
    top: 2px;
  }
  a:focus-visible {
    outline: 2px solid #111;
    outline-offset: 2px;
  }
  .name a:hover,
  .name a:active {
    top: 0;
  }

  .material-icons {
    font-family: "Material Icons";
    font-weight: normal;
    font-style: normal;
    font-size: 24px;
    line-height: 1;
    letter-spacing: normal;
    text-transform: none;
    display: inline-block;
    white-space: nowrap;
    word-wrap: normal;
    direction: ltr;
    -webkit-font-smoothing: antialiased;
  }

  .special {
    font-family: "Bebas Neue", sans-serif;
    font-weight: 400;
    font-style: normal;
    font-size: clamp(1.75rem, 5vw, 2.25rem);
    line-height: 1;
  }

  .name {
    flex: 1 1 auto;
    min-width: 0;
    white-space: nowrap;
    margin: 0;
  }
  .contact,
  .social {
    color: #000;
  }
  .contact {
    max-width: 50px;
  }
  .social {
    max-width: 35px;
  }

  img {
    display: block;
    width: 30px;
    height: 30px;
    padding: .25rem;
  }

  @media (prefers-reduced-motion: reduce) {
    a {
      transition: none;
    }
  }

  @media (max-width: 600px) {
    nav {
      width: 100%;
    }
    .contact,
    img {
      padding: 0.25rem;
    }
    .inner {
      width: 100%;
      justify-content: space-between;
    }
  }
</style>

<script>
  const navigation = document.querySelector(".inner");

  if (navigation instanceof HTMLElement) {
    navigation.addEventListener("click", (event) => {
      const link = event.target instanceof Element ? event.target.closest("a[data-nav-icon]") : null;

      if (!(link instanceof HTMLAnchorElement)) {
        return;
      }

      const iconName = link.dataset.navIcon || "";

      if (typeof window.gtag === "function") {
        window.gtag("event", "navigation_icon_click", {
          icon_name: iconName,
          link_url: link.href
        });

        if (iconName) {
          window.gtag("event", `${iconName}_click`, {
            icon_name: iconName,
            link_url: link.href
          });
        }
      }
    });
  }
</script>
