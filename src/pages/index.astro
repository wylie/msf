---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Thumbnails from '../components/Thumbnails.astro';
import Hero from '../components/Hero.astro';
---

<Layout
  title="Mark S. Fisher" 
  description="View the work of Mark S. Fisher" 
  image="/msf/img/custom-social-image.png"
>
	<Navigation style="grid-column: 1 / -1;" />
	<div class="content-row">
		<div class="hero-panel">
			<Hero />
		</div>
		<div class="thumbs-panel">
			<Thumbnails />
		</div>
	</div>
</Layout>

<style>
	.content-row {
		display: grid;
		grid-template-columns: 100px minmax(0, 1fr);
		grid-template-areas: "thumbs hero";
		align-items: stretch;
		width: min(100%, 1042px);
		max-width: 100%;
		aspect-ratio: 1036 / 621;
		overflow: hidden;
	}

	.hero-panel {
		grid-area: hero;
		min-width: 0;
		min-height: 0;
		overflow: hidden;
	}

	.thumbs-panel {
		grid-area: thumbs;
		min-width: 0;
		min-height: 0;
		overflow: hidden;
	}

	.content-row > * {
		height: 100%;
		min-height: 0;
	}

	@media (max-width: 600px) {
		.content-row {
			grid-template-columns: 1fr;
			grid-template-areas:
				"hero"
				"thumbs";
			grid-template-rows: auto 100px;
			aspect-ratio: auto;
			height: auto;
			max-height: none;
		}
	}
</style>
